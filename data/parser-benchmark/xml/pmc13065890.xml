<table-wrap id="Tabd" position="float" orientation="portrait"><table frame="hsides" rules="groups"><thead><tr><th align="left" colspan="1" rowspan="1">Author</th><th align="left" colspan="1" rowspan="1">Imaging</th><th align="left" colspan="1" rowspan="1">Mean RVEDVi (ml/m<sup>2</sup>)</th><th align="left" colspan="1" rowspan="1">Mean RVESVi (ml/m<sup>2</sup>)</th><th align="left" colspan="1" rowspan="1">Mean LVEDVi (ml/m<sup>2</sup>)</th><th align="left" colspan="1" rowspan="1">Mean LVESVi (ml/m<sup>2</sup>)</th><th align="left" colspan="1" rowspan="1">Mean LVEF (%)</th></tr></thead><tbody><tr><td align="left" colspan="1" rowspan="1">Sarikouch 2011 [1]</td><td align="left" colspan="1" rowspan="1">CMR</td><td align="left" colspan="1" rowspan="1"><p>M:124.8±34.7</p><p>F: 114.9±29.9</p></td><td align="left" colspan="1" rowspan="1"><p>M:65.2±25.7</p><p>F:55.5±20.1</p></td><td align="left" colspan="1" rowspan="1"><p>M:83.8±18.5</p><p>F:77.5±14.7</p></td><td align="left" colspan="1" rowspan="1"><p>M:37.3±14.4</p><p>F:32.5±9.8</p></td><td align="left" colspan="1" rowspan="1"><p>M:56.0±8.4</p><p>F:58.2±8.3</p></td></tr></tbody></table></table-wrap></p></body><back><fn-group><fn><p><bold>Publisher's Note</bold></p><p>Springer Nature remains neutral with regard to jurisdictional claims in published maps and institutional affiliations.</p></fn></fn-group></back></article>