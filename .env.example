# ── Server (Railway) ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_BASE_URL=http://localhost:3000
CLIENT_BASE_URL=http://localhost:3001
CORS_ALLOWED_ORIGINS=

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
RESEND_API_KEY=re_xxxxxxxxx
MAIL_FROM=info@journi.com
MAIL_REPLY_TO=support@journi.com
SUPPORT_EMAIL=support@journi.com
RESET_PASSWORD_REDIRECT_URL=http://localhost:3001/reset-password

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO_MONTHLY=
STRIPE_PRICE_ID_PRO_YEARLY=
BILLING_PLAN_CODE=pro_monthly

JOURNAL_CACHE_TTL_SECONDS=120
JOURNAL_SYNC_STALE_HOURS=168
WS_SNAPSHOT_DEBOUNCE_MS=15000
INVITE_TOKEN_TTL_HOURS=168

# ── LLM Parsing ───────────────────────────────────────────────────────────────
# Anthropic Claude API key — used for manuscript reformatter + LLM parsing fallback
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# Ollama (self-hosted, zero data exposure) - used for document parsing
# Local development:
#   OLLAMA_BASE_URL=http://127.0.0.1:11434
#   ollama pull qwen2.5:3b
#
# Railway deployment:
#   OLLAMA_BASE_URL=http://ollama.railway.internal:11434
#   OLLAMA_MODEL=qwen2.5:3b
#   (Requires Ollama service attached to your Railway project)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b

# ── Frontend (Vercel) — set these as environment variables in the Vercel dashboard ──
# VITE_API_BASE_URL=https://YOUR_RAILWAY_APP.railway.app/api
# VITE_WS_BASE_URL=wss://YOUR_RAILWAY_APP.railway.app/ws/collab

